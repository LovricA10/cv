    .job-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .company {
        font-size: 0.9rem;
        color: var(--color-primary);
        font-weight: 500;
    }

    .card-desc {
        font-size: 0.9rem;
