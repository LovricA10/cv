<section class="section">
    <h2 class="section-title">
        <img src="/icons/work.svg" alt="" />
        Radno iskustvo
    </h2>

    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="job-title">Stručna praksa</h3>
                <a href="#" class="company">MicroCache</a>
            </div>
            <span class="period">09/2025 – 05/2026</span>
        </div>

        <p class="card-desc">
            Tijekom prakse radio sam na razvoju web aplikacija i koristio se s modernim
