---
const jezici = [
    { naziv: "Hrvatski", razina: "Maternji" },
    { naziv: "Engleski", razina: "Tečno" },
];
---

<section class="section">
    <h2 class="section-title">
        <img src="/icons/languages.svg" alt="" />
        Jezici
    </h2>

    <div class="lang-grid">
        {jezici.map((j) => (
                <div class="card lang-card">
                    <h3 class="lang-naziv">{j.naziv}</h3>
                    <p class="lang-razina">{j.razina}</p>
                </div>
        ))}
    </div>
</section>

<style>
    .lang-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .lang-naziv {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .lang-razina {
        font-size: 0.9rem;
        color: var(--color-primary);
        font-weight: 500;
    }
</style>