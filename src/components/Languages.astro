---
const jezici = [
    { naziv: "Hrvatski", razina: "Maternji" },
    { naziv: "Engleski", razina: "Tečno" },
];
---

<section class="section">
    <h2 class="section-title">
        <img src="/icons/languages.svg" alt="" />
        <span data-i18n="languages.title">Jezici</span>
    </h2>

    <div class="lang-grid">
        {jezici.map((j, i) => (
            <div class="card lang-card">
                <h3 class="lang-naziv" data-i18n={`languages.items.${i}.name`}>{j.naziv}</h3>
                <p class="lang-razina" data-i18n={`languages.items.${i}.level`}>{j.razina}</p>
            </div>
        ))}
    </div>
</section>

<style>
    .lang-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .lang-naziv {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .lang-razina {
        font-size: 0.9rem;
        color: var(--color-primary);
        font-weight: 500;
    }
</style>
