---
const stavke = [
    "Izrada web aplikacija (frontend + backend)",
    "Razvoj desktop aplikacija u Javi i C#",
    "Implementacija algoritama i struktura podataka u C++",
    "Rad s bazama podataka i kompleksnim SQL upitima",
];
---

<section class="section">
    <h2 class="section-title">
        <img src="/icons/projects.svg" alt="" />
        <span data-i18n="projects.title">Projekti</span>
    </h2>

    <div class="card">
        <p class="card-desc" data-i18n="projects.desc">Tijekom studija radio sam na više projekata koji uključuju:</p>
        <ul class="bullet-list">
            {stavke.map((item, i) => (
                <li data-i18n={`projects.items.${i}`}>{item}</li>
            ))}
        </ul>
    </div>
</section>

<style>
    .card-desc {
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        line-height: 1.6;
    }
</style>
